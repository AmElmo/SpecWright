  "user_flows": [
    {
      "id": "flow_accept_completion",
      "name": "Accept an Inline Completion",
      "steps": [
        { "step": 1, "screen": "editor-with-suggestions", "action": "Developer types 'async get' inside a class" },
        { "step": 2, "screen": "editor-with-suggestions", "action": "Ghost text appears: 'getUserByEmail(email: string)'" },
        { "step": 3, "screen": "editor-with-suggestions", "action": "Developer presses Tab to accept the suggestion" },
        { "step": 4, "screen": "editor-with-suggestions", "action": "Code is inserted and import for User type is auto-added" }
      ]
    },
    {
      "id": "flow_initial_indexing",
      "name": "First-Time Project Indexing",
      "steps": [
        { "step": 1, "screen": "editor-with-suggestions", "action": "Developer opens a project for the first time" },
        { "step": 2, "screen": "indexing-status", "action": "Status bar shows 'Indexing...' with file count progress" },
        { "step": 3, "screen": "indexing-status", "action": "Panel shows per-language breakdown of indexed files" },
        { "step": 4, "screen": "editor-with-suggestions", "action": "Status bar shows green 'Index: ready' and suggestions begin" }
      ]
